# Required
BAILIAN_API_KEY=your-bailian-api-key
SECRET_KEY=change-me-to-a-random-string

# Optional
DB_PASSWORD=culturalbridge

# Frontend public origin (used at Docker build time)
# 仅 dev 直连后端时取消注释并填绝对地址(如 http://localhost:8000)。
# 走 /mca 子路径(prod)时必须留空,否则绝对地址会覆盖 NEXT_PUBLIC_BASE_PATH 前缀。
# NEXT_PUBLIC_API_URL=http://localhost
# NEXT_PUBLIC_WS_URL=ws://localhost
# 公网子路径前缀:prod=/mca,dev 留空。需重建前端。
NEXT_PUBLIC_BASE_PATH=/mca

# Backend CORS origin and migration behavior
FRONTEND_URL=http://localhost
RUN_MIGRATIONS=true
